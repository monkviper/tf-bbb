{% doc %}
  Hero Carousel Slide Block

  Renders a single slide for the hero carousel section with background image,
  trust badge, heading, subheading, and CTA button.

  @example {% content_for 'block', type: '_hero-carousel-slide', id: 'slide-1' %}
{% enddoc %}

{% liquid
  assign slide_index = section.blocks | find_index: 'id', block.id
  assign total_slides = section.blocks.size
  assign content_alignment_desktop = section.settings.content_alignment_desktop | default: 'left'
  assign content_alignment_mobile = section.settings.content_alignment_mobile | default: 'left'
%}

<div
  class="hero-carousel__slide{% if slide_index == 0 %} hero-carousel__slide--active{% endif %}"
  {{ block.shopify_attributes }}
  ref="slides[]"
  role="group"
  aria-roledescription="slide"
  aria-label="{{ 'accessibility.hero_carousel_slide_status' | t: current: slide_index | plus: 1, total: total_slides }}"
  {% if slide_index != 0 %}aria-hidden="true"{% endif %}
>
  <div class="hero-carousel__media">
    {% if block.settings.image != blank %}
      <picture>
        {% if block.settings.image_mobile != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ block.settings.image_mobile | image_url: width: block.settings.image_mobile.width }}"
          >
        {% endif %}
        {{
          block.settings.image
          | image_url: width: block.settings.image.width
          | image_tag:
            sizes: '100vw',
            widths: '375,550,750,1100,1500,1780,2000,2400',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero-carousel__image',
            alt: block.settings.heading
        }}
      </picture>
    {% else %}
      <div class="hero-carousel__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-carousel__placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  <div
    class="hero-carousel__content"
    style="
      --content-alignment-desktop: {{ content_alignment_desktop }};
      --content-alignment-mobile: {{ content_alignment_mobile }};
    "
  >
    <div class="hero-carousel__content-inner">
      {% if block.settings.trust_text != blank %}
        <div class="hero-carousel__trust-badge">
          <span class="hero-carousel__trust-text">{{ block.settings.trust_text | escape }}</span>
          {% if block.settings.show_stars %}
            <span class="hero-carousel__stars hero-carousel__stars--desktop">
              {{ '4-stars-and-up-2.svg' | inline_asset_content }}
            </span>
            <span class="hero-carousel__stars hero-carousel__stars--mobile">
              {{ '4-stars-and-up.svg' | inline_asset_content }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="hero-carousel__heading">{{ block.settings.heading | escape }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <p class="hero-carousel__subheading">{{ block.settings.subheading | escape }}</p>
      {% endif %}

      {% if block.settings.button_label != blank %}
        <a
          {% if block.settings.button_link != blank %}href="{{ block.settings.button_link }}"{% endif %}
          class="hero-carousel__button"
        >
          {{ block.settings.button_label | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:names.hero_carousel_slide",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:settings.image_mobile"
    },
    {
      "type": "image_picker",
      "id": "thumbnail_image",
      "label": "t:settings.thumbnail_image"
    },
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "t:settings.trust_text",
      "default": "Trusted by over 5 million users"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "t:settings.show_stars",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Conquer Every Climate."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:settings.subheading",
      "default": "Reliable lithium power in the harshest conditions."
    },
    {
      "type": "header",
      "content": "t:content.buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:settings.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:settings.button_link"
    }
  ]
}
{% endschema %}
