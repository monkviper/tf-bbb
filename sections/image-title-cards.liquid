<div
  class='image-title-cards section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}'
  style='
    --padding-block-start: {{ section.settings.padding-block-start }}px;
    --padding-block-end: {{ section.settings.padding-block-end }}px;
  '
>
  <div class='image-title-cards__inner spacing-style' style="{% render 'spacing-style', settings: section.settings %}">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class='image-title-cards__header'>
        {% if section.settings.heading != blank %}
          <h2 class='image-title-cards__heading'>{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class='image-title-cards__subheading'>{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class='image-title-cards__grid'>
      {% for block in section.blocks %}
        <article class='image-title-cards__card' {{ block.shopify_attributes }}>
          <div class='image-title-cards__image-wrapper'>
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: block.settings.image.width
                | image_tag:
                  sizes: '(min-width: 750px) 224px, 224px',
                  widths: '224,448,550',
                  loading: 'lazy',
                  class: 'image-title-cards__image',
                  alt: block.settings.image.alt
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'image-title-cards__placeholder' }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class='image-title-cards__card-title'>{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class='image-title-cards__card-description'>{{ block.settings.description | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.image-title-cards {
  background-color: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.image-title-cards__inner {
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;

  @media screen and (max-width: 749px) {
    gap: 32px;
  }
}

.image-title-cards__header {
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: center;
  text-align: center;
  max-width: 100%;
}

.image-title-cards__heading {
  font-family: var(--font-heading--family);
  font-weight: 600;
  font-size: 2rem;
  line-height: 45px;
  letter-spacing: -0.64px;
  color: var(--color-foreground-heading, rgb(var(--color-foreground)));
  margin: 0;

  @media screen and (max-width: 749px) {
    font-size: 1.5rem;
    line-height: 34px;
    letter-spacing: -0.48px;
  }
}

.image-title-cards__subheading {
  font-family: var(--font-body--family);
  font-weight: 400;
  font-size: 1rem;
  line-height: 22px;
  letter-spacing: 0;
  color: var(--ds-color-dark-gray, #4F5055);
  margin: 0;
  max-width: 1248px;
}

.image-title-cards__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 32px;
  width: 100%;

  @media screen and (max-width: 749px) {
    grid-template-columns: repeat(5, min(224px, 58vw));
    grid-auto-flow: column;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    gap: 16px;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }
}

.image-title-cards__card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: center;

  @media screen and (max-width: 749px) {
    scroll-snap-align: start;
  }
}

.image-title-cards__image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 12px;
  overflow: hidden;
}

.image-title-cards__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.image-title-cards__placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.image-title-cards__card-title {
  font-family: var(--font-heading--family);
  font-weight: 600;
  font-size: 1rem;
  line-height: 22px;
  letter-spacing: 0;
  color: var(--color-foreground-heading, rgb(var(--color-foreground)));
  margin: 0;
  width: 100%;
}

.image-title-cards__card-description {
  font-family: var(--font-body--family);
  font-weight: 400;
  font-size: 0.875rem;
  line-height: 20px;
  letter-spacing: 0;
  color: var(--ds-color-dark-gray, #4F5055);
  margin: 0;
  width: 100%;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.image_title_cards",
  "tag": "section",
  "class": "image-title-cards-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Power Solutions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "At Battle Born Batteries, our goal is to power your ideal RV experience. We build our lithium-ion RV batteries to perform better, last longer, and provide the deliverable power"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:names.card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:settings.title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:settings.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:names.image_title_cards",
      "category": "t:categories.collections",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Life PO4 Batteries",
            "description": "Life PO4 batteries built for reliable power"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Charging & Power",
            "description": "Charging and power conversion components"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Solar Panels",
            "description": "Solar components for off-grid power systems"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Monitoring & Control",
            "description": "Smart system monitoring and control"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Complete Systems",
            "description": "Integrated power systems designed to work together."
          }
        }
      ]
    }
  ]
}
{% endschema %}
