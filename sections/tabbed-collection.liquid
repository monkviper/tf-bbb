{%- liquid
  assign active_tab = 0
  assign blocks_size = section.blocks.size
-%}

<tabbed-collection
  data-section-id="{{ section.id }}"
  class="section section--{{ section.settings.section_width }} spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="tc-wrapper">
    <div class="tc-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="tc-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if blocks_size > 0 -%}
        <div class="tc-tabs" role="tablist" aria-label="{{ section.settings.heading | escape }}">
          {%- for block in section.blocks -%}
            <button
              class="tc-tab{% if forloop.index0 == active_tab %} tc-tab--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.index0 == active_tab %}true{% else %}false{% endif %}"
              aria-controls="tc-panel-{{ section.id }}-{{ forloop.index0 }}"
              id="tc-tab-{{ section.id }}-{{ forloop.index0 }}"
              data-tab-index="{{ forloop.index0 }}"
              on:click="/handleTabClick"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | escape }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        <p
          class="tc-description{% unless forloop.index0 == active_tab %} tc-description--hidden{% endunless %}"
          data-tab-description="{{ forloop.index0 }}"
          id="tc-desc-{{ section.id }}-{{ forloop.index0 }}"
        >
          {%- if block.settings.description != blank -%}
            {{ block.settings.description | escape }}
          {%- endif -%}
        </p>
      {%- endfor -%}
    </div>

    {%- for block in section.blocks -%}
      {%- assign collection = block.settings.collection -%}
      <div
        class="tc-products{% unless forloop.index0 == active_tab %} tc-products--hidden{% endunless %}"
        role="tabpanel"
        id="tc-panel-{{ section.id }}-{{ forloop.index0 }}"
        aria-labelledby="tc-tab-{{ section.id }}-{{ forloop.index0 }}"
        data-tab-panel="{{ forloop.index0 }}"
      >
        {%- if collection != blank and collection.products.size > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            {% render 'tabbed-collection-card',
              product: product,
              show_badge: section.settings.show_badge,
              badge_text: section.settings.badge_text,
              quickview_label: section.settings.quickview_label
            %}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..section.settings.products_to_show) -%}
            <div class="tc-card tc-card--placeholder">
              <div class="tc-card__media">
                {{ 'product-1' | placeholder_svg_tag: 'tc-card__placeholder-svg' }}
              </div>
              <div class="tc-card__content">
                <div class="tc-card__info">
                  <h3 class="tc-card__title">{{ 'general.card.product_title' | t | default: 'Example product title' }}</h3>
                  <div class="tc-card__price">
                    <span class="tc-card__price-sale">{{ 67900 | money }}</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</tabbed-collection>

{% stylesheet %}
  tabbed-collection {
    display: block;
    box-shadow: inset 0 20px 20px rgba(0, 0, 0, 0.03);
  }

  .tc-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .tc-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
  }

  .tc-heading {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 32px;
    line-height: 45px;
    letter-spacing: -0.64px;
    text-align: center;
    color: var(--ds-color-black, #151515);
    margin: 0;
  }

  .tc-tabs {
    display: flex;
    flex-direction: row;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    border-bottom: 1px solid var(--ds-color-medium-gray, #888B95);
    max-width: 100%;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .tc-tab {
    flex-shrink: 0;
    padding: 8px 24px;
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-medium-gray, #888B95);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    margin-bottom: -1px;
    transition: color 0.2s ease, border-color 0.2s ease;

    &:hover {
      color: var(--ds-color-dark-gray, #4F5055);
    }

    &:focus-visible {
      outline: 2px solid var(--ds-color-light-blue, #005695);
      outline-offset: -2px;
    }
  }

  .tc-tab--active {
    font-weight: var(--ds-font-weight-semibold, 600);
    color: var(--ds-color-black, #151515);
    border-bottom-color: var(--ds-color-light-blue, #005695);
  }

  .tc-description {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    text-align: center;
    color: var(--ds-color-dark-gray, #4F5055);
    margin: 0;
    max-width: 1308px;
  }

  .tc-description--hidden {
    display: none;
  }

  .tc-products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    width: 100%;
  }

  .tc-products--hidden {
    display: none;
  }

  /* Product card styles */
  .tc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tc-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .tc-card__media {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background: var(--ds-color-lightest-gray, #F2F2F2);
    aspect-ratio: 303 / 308;
  }

  .tc-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tc-card__placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .tc-card__badge {
    position: absolute;
    top: 8px;
    inset-inline-start: 8px;
    z-index: 2;
    padding: 2px 10px;
    border-radius: 4px;
    background: var(--ds-color-lightest-blue, #DCE4F0);
    color: var(--ds-color-light-blue, #005695);
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    white-space: nowrap;
  }

  .tc-card__icons {
    position: absolute;
    top: 8px;
    inset-inline-end: 8px;
    z-index: 2;
    display: flex;
    flex-direction: row;
    gap: 8px;
  }

  .tc-card__icon-circle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 24px;
    height: 24px;
    border-radius: 48px;
    background: var(--ds-color-white, #FFFFFF);

    img {
      width: 16px;
      height: 16px;
      object-fit: contain;
    }
  }

  .tc-card__content {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 16px 0;
  }

  .tc-card__info {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .tc-card__rating {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .tc-card__stars {
    display: flex;
    flex-direction: row;
    gap: 0;

    svg {
      width: 16px;
      height: 16px;
    }
  }

  .tc-card__rating-text {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2px;
  }

  .tc-card__rating-value {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-black, #151515);
  }

  .tc-card__rating-count {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-black, #151515);
  }

  .tc-card__title {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 14px;
    line-height: 22px;
    color: var(--ds-color-black, #151515);
    margin: 0;
  }

  .tc-card__title-link {
    text-decoration: none;
    color: inherit;
    position: relative;
    z-index: 2;
  }

  .tc-card__price {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tc-card__price-sale {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-black, #151515);
  }

  .tc-card__price-compare {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-medium-gray, #888B95);
    text-decoration: line-through;
  }

  .tc-card__discount-badge {
    padding: 3px 6px;
    border-radius: 4px;
    background: var(--ds-color-light-red, #FFEEED);
    color: var(--ds-color-red, #D90400);
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    white-space: nowrap;
  }

  .tc-card__quickview {
    position: relative;
    z-index: 2;
    display: inline-block;
    width: fit-content;
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-light-blue, #005695);
    text-decoration: underline;
    text-underline-offset: 2px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;

    &:hover {
      text-decoration-thickness: 2px;
    }

    &:focus-visible {
      outline: 2px solid var(--ds-color-light-blue, #005695);
      outline-offset: 2px;
    }
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 989px) {
    .tc-wrapper {
      gap: 24px;
    }

    .tc-heading {
      font-size: 24px;
      line-height: 34px;
      letter-spacing: -0.48px;
    }

    .tc-header {
      gap: 16px;
    }

    .tc-description {
      font-size: 14px;
      line-height: 20px;
    }

    .tc-products {
      display: flex;
      flex-direction: row;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;

      &::-webkit-scrollbar {
        display: none;
      }
    }

    .tc-products--hidden {
      display: none;
    }

    .tc-card {
      min-width: 303px;
      scroll-snap-align: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tc-tab {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  import '@theme/tabbed-collection';
{% endjavascript %}

{% schema %}
{
  "name": "t:names.tabbed_collection",
  "tag": "section",
  "class": "tabbed-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Explore Best Sellers"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:settings.products_to_show",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "t:settings.show_badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:settings.badge_text",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "quickview_label",
      "label": "t:settings.quickview_label",
      "default": "Quickview"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "t:names.collection_tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:settings.label",
          "default": "Collection"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:settings.description"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "t:settings.collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "t:names.tabbed_collection",
      "category": "t:categories.products",
      "settings": {
        "heading": "Explore Best Sellers",
        "products_to_show": 4,
        "show_badge": true,
        "badge_text": "Best Seller",
        "quickview_label": "Quickview",
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 64,
        "padding-block-end": 64
      },
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "label": "LiFePO₄ Batteries",
            "description": "Power lights, fans, furnace, water pump, refrigerator, satellite Internet & everyday essentials reliably through the night"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Smart LiFePO₄ Batteries",
            "description": "Smart monitoring and control for your lithium battery system"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Inverter Power",
            "description": "Convert battery power to household AC for all your devices"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Solar Integration",
            "description": "Harness solar energy to charge and maintain your battery bank"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Alternator Charging",
            "description": "Charge your batteries efficiently while driving with alternator charging solutions"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
