{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign blocks_size = section.blocks.size
-%}

<tabbed-collection
  data-section-id="{{ section.id }}"
  class="section section--{{ section.settings.section_width }} spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="tabbed-collection">
    <div class="tabbed-collection__header">
      {% if section.settings.heading != blank %}
        <h2 class="tabbed-collection__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if blocks_size > 0 %}
        <div class="tabbed-collection__tabs" role="tablist" aria-label="{{ section.settings.heading | escape }}">
          {% for block in section.blocks %}
            <button
              role="tab"
              ref="tab[]"
              on:click="/handleTabClick/{{ forloop.index0 }}"
              class="tabbed-collection__tab{% if forloop.index0 == 0 %} tabbed-collection__tab--active{% endif %}"
              aria-selected="{% if forloop.index0 == 0 %}true{% else %}false{% endif %}"
              aria-controls="tabbed-collection-panel-{{ section.id }}-{{ forloop.index0 }}"
              data-tab-index="{{ forloop.index0 }}"
              id="tabbed-collection-tab-{{ section.id }}-{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | escape }}
            </button>
          {% endfor %}
        </div>
      {% endif %}

      {% for block in section.blocks %}
        {% if block.settings.description != blank %}
          <p
            ref="description[]"
            class="tabbed-collection__description"
            data-tab-index="{{ forloop.index0 }}"
            {% if forloop.index0 != 0 %}hidden{% endif %}
          >
            {{ block.settings.description | escape }}
          </p>
        {% endif %}
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      {%- assign tab_collection = block.settings.collection -%}
      <div
        ref="panel[]"
        role="tabpanel"
        id="tabbed-collection-panel-{{ section.id }}-{{ forloop.index0 }}"
        aria-labelledby="tabbed-collection-tab-{{ section.id }}-{{ forloop.index0 }}"
        class="tabbed-collection__grid"
        data-tab-index="{{ forloop.index0 }}"
        {% if forloop.index0 != 0 %}hidden{% endif %}
      >
        {% if tab_collection != blank %}
          {% for product in tab_collection.products limit: products_to_show %}
            {% render 'tabbed-collection-card',
              product: product,
              show_badge: section.settings.show_badge,
              badge_text: section.settings.badge_text,
              quickview_label: section.settings.quickview_label,
              show_feature_icons: section.settings.show_feature_icons
            %}
          {% endfor %}
        {% else %}
          {% for i in (1..products_to_show) %}
            <article class="tabbed-card tabbed-card--placeholder">
              <div class="tabbed-card__media">
                {{ 'product-1' | placeholder_svg_tag: 'tabbed-card__placeholder-svg' }}
              </div>
              <div class="tabbed-card__content">
                <div class="tabbed-card__info">
                  <h3 class="tabbed-card__title">{{ 'content.product_card_placeholder' | t }}</h3>
                  <div class="tabbed-card__price">
                    <span class="tabbed-card__price-sale">{{ 0 | money }}</span>
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</tabbed-collection>

{% stylesheet %}
  .tabbed-collection {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .tabbed-collection__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: 1030px;
    width: 100%;
  }

  .tabbed-collection__heading {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 32px;
    line-height: 45px;
    letter-spacing: -0.64px;
    text-align: center;
    color: var(--ds-color-black, #151515);
    margin: 0;
  }

  .tabbed-collection__tabs {
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 1px solid var(--ds-color-medium-gray, #888B95);
    border-radius: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    max-width: 100%;
    padding: 0 32px;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .tabbed-collection__tab {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-medium-gray, #888B95);
    background: none;
    border: 1px solid var(--ds-color-medium-gray, #888B95);
    padding: 8px 24px;
    cursor: pointer;
    white-space: nowrap;
    margin-inline-start: -1px;
    transition: color 0.15s ease, border-color 0.15s ease;

    &:first-child {
      margin-inline-start: 0;
    }

    &:hover {
      color: var(--ds-color-black, #151515);
    }

    &:focus-visible {
      outline: 2px solid var(--ds-color-light-blue, #005695);
      outline-offset: -2px;
      z-index: 1;
    }
  }

  .tabbed-collection__tab--active {
    font-weight: var(--ds-font-weight-semibold, 600);
    color: var(--ds-color-black, #151515);
    border-color: var(--ds-color-light-blue, #005695);
    z-index: 1;
  }

  .tabbed-collection__description {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    text-align: center;
    color: var(--ds-color-dark-gray, #4F5055);
    margin: 0;
    max-width: 1308px;
  }

  .tabbed-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    width: 100%;
  }

  .tabbed-collection__grid[hidden] {
    display: none;
  }

  .tabbed-collection__description[hidden] {
    display: none;
  }

  /* Card styles */
  .tabbed-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tabbed-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .tabbed-card__media {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background-color: var(--ds-color-lightest-gray, #F2F2F2);
  }

  .tabbed-card__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
  }

  .tabbed-card__placeholder {
    aspect-ratio: 303 / 308;
    background-color: var(--ds-color-lightest-gray, #F2F2F2);
    border-radius: 4px;
  }

  .tabbed-card__placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .tabbed-card__badge {
    position: absolute;
    top: 8px;
    inset-inline-start: 8px;
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-light-blue, #005695);
    background-color: var(--ds-color-lightest-blue, #DCE4F0);
    padding: 2px 10px;
    border-radius: 4px;
    z-index: 2;
  }

  .tabbed-card__content {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 16px 0;
  }

  .tabbed-card__info {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .tabbed-card__rating {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .tabbed-card__stars {
    display: flex;
    flex-direction: row;
    gap: 4px;

    svg {
      flex-shrink: 0;
    }
  }

  .tabbed-card__rating-text {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2px;
  }

  .tabbed-card__rating-value {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-black, #151515);
  }

  .tabbed-card__rating-count {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-black, #151515);
  }

  .tabbed-card__title {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 14px;
    line-height: 22px;
    color: var(--ds-color-black, #151515);
    margin: 0;

    a {
      text-decoration: none;
      color: inherit;
      position: relative;
      z-index: 2;
    }
  }

  .tabbed-card__price {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tabbed-card__price-sale {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-black, #151515);
  }

  .tabbed-card__price-compare {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-medium-gray, #888B95);
    text-decoration: line-through;
  }

  .tabbed-card__discount-badge {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-normal, 400);
    font-size: 12px;
    line-height: 17px;
    color: var(--ds-color-red, #D90400);
    background-color: var(--ds-color-light-red, #FFEEED);
    padding: 3px 6px;
    border-radius: 4px;
  }

  .tabbed-card__quickview {
    font-family: var(--ds-font-family, 'Poppins', sans-serif);
    font-weight: var(--ds-font-weight-semibold, 600);
    font-size: 16px;
    line-height: 22px;
    color: var(--ds-color-light-blue, #005695);
    text-decoration: none;
    border-bottom: 1px solid var(--ds-color-light-blue, #005695);
    padding-bottom: 1px;
    display: inline-flex;
    align-self: flex-start;
    position: relative;
    z-index: 2;

    &:hover {
      opacity: 0.8;
    }

    &:focus-visible {
      outline: 2px solid var(--ds-color-light-blue, #005695);
      outline-offset: 2px;
    }
  }

  /* Feature icons */
  .tabbed-card__feature-icons {
    position: absolute;
    bottom: 8px;
    inset-inline-start: 8px;
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .tabbed-card__feature-icon {
    width: 24px;
    height: 24px;
    border-radius: 48px;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;

    img {
      width: 16px;
      height: 16px;
    }
  }

  /* Inner shadow matching Figma */
  tabbed-collection {
    box-shadow: inset 0 20px 20px rgba(0, 0, 0, 0.03);
  }

  /* Mobile */
  @media screen and (max-width: 989px) {
    .tabbed-collection {
      gap: 24px;
    }

    .tabbed-collection__header {
      gap: 16px;
    }

    .tabbed-collection__heading {
      font-size: 24px;
      line-height: 34px;
      letter-spacing: -0.48px;
    }

    .tabbed-collection__description {
      font-size: 14px;
      line-height: 20px;
    }

    .tabbed-collection__grid:not([hidden]) {
      display: flex;
      flex-direction: row;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;

      &::-webkit-scrollbar {
        display: none;
      }
    }

    .tabbed-card {
      min-width: 303px;
      scroll-snap-align: start;
    }
  }

  /* SR only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

{% javascript %}
  import '@theme/tabbed-collection';
{% endjavascript %}

{% schema %}
{
  "name": "t:names.tabbed_collection",
  "tag": "div",
  "class": "tabbed-collection-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Explore Best Sellers"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:settings.products_to_show",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "t:settings.show_badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:settings.badge_text",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "quickview_label",
      "label": "t:settings.quickview_label",
      "default": "Quickview"
    },
    {
      "type": "checkbox",
      "id": "show_feature_icons",
      "label": "t:settings.show_feature_icons",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "t:names.collection_tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:settings.label"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:settings.description"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "t:settings.collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "t:names.tabbed_collection",
      "category": "t:categories.products",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "label": "LiFePO₄ Batteries",
            "description": "Power lights, fans, furnace, water pump, refrigerator, satellite Internet & everyday essentials reliably through the night"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Smart LiFePO₄ Batteries",
            "description": "Smart monitoring and control for your lithium battery system"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Inverter Power",
            "description": "Convert battery power to household AC for all your devices"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Solar Integration",
            "description": "Harness solar energy to charge and maintain your battery bank"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Alternator Charging",
            "description": "Charge your batteries efficiently while driving with alternator charging solutions"
          }
        }
      ]
    }
  ]
}
{% endschema %}
