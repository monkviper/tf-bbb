{% style %}
  :root {
    /* Brand Colors - Core */
    --ds-color-dark-blue: #081D4D;
    --ds-color-royal-blue: #001F5F;
    --ds-color-blue: #02267E;
    --ds-color-medium-blue: #013C82;
    --ds-color-light-blue: #005695;
    --ds-color-lightest-blue: #DCE4F0;
    --ds-color-black: #151515;
    --ds-color-light-red: #FFEEED;
    --ds-color-red: #D90400;

    /* Grayscale */
    --ds-color-dark-gray: #4F5055;
    --ds-color-medium-gray: #888B95;
    --ds-color-light-gray: #A7A9B4;
    --ds-color-lighter-gray: #C9CAD4;
    --ds-color-lightest-gray: #F2F2F2;
    --ds-color-white: #FFFFFF;

    /* Warning Scale */
    --ds-color-warning-50: #FEFEF6;
    --ds-color-warning-100: #FEFCEF;
    --ds-color-warning-200: #FCF9E1;
    --ds-color-warning-300: #FBF6D3;
    --ds-color-warning-400: #FAF2C5;
    --ds-color-warning-500: #F9EDB7;
    --ds-color-warning-600: #F7E8A9;
    --ds-color-warning-700: #F6E39B;
    --ds-color-warning-800: #F5DD8D;
    --ds-color-warning-900: #F3D476;
    --ds-color-warning-950: #F2CF6A;

    /* Error Scale */
    --ds-color-error-50: #FFEEED;
    --ds-color-error-100: #FFE1E1;
    --ds-color-error-200: #FFC8C7;
    --ds-color-error-300: #FFAFAE;
    --ds-color-error-400: #FF9694;
    --ds-color-error-500: #FF7D7B;
    --ds-color-error-600: #FF6461;
    --ds-color-error-700: #FF4B48;
    --ds-color-error-800: #FF322E;
    --ds-color-error-900: #F50500;
    --ds-color-error-950: #D90400;

    /* Success Scale */
    --ds-color-success-50: #EEF5EC;
    --ds-color-success-100: #E4EFE0;
    --ds-color-success-200: #D0E3C8;
    --ds-color-success-300: #BCD7B1;
    --ds-color-success-400: #A7CB99;
    --ds-color-success-500: #93BF81;
    --ds-color-success-600: #7FB36A;
    --ds-color-success-700: #6BA554;
    --ds-color-success-800: #5C8D48;
    --ds-color-success-900: #446835;
    --ds-color-success-950: #38552C;

    /* Typography */
    --ds-font-family: 'Poppins', sans-serif;
    --ds-font-weight-normal: 400;
    --ds-font-weight-medium: 500;
    --ds-font-weight-semibold: 600;
  }
{% endstyle %}
