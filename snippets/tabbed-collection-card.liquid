{% doc %}
  Tabbed Collection Product Card

  Renders a product card for the tabbed collection section with image,
  badge, star rating, title, price with discount, and quickview link.

  @param {object} product - Product object (required)
  @param {boolean} [show_badge] - Whether to show the badge overlay (default: true)
  @param {string} [badge_text] - Text for the badge (default: 'Best Seller')
  @param {string} [quickview_label] - Label for quickview link (default: 'Quickview')

  @example
  {% render 'tabbed-collection-card',
    product: product,
    show_badge: true,
    badge_text: 'Best Seller',
    quickview_label: 'Quickview'
  %}
{% enddoc %}

{% liquid
  assign product = product | default: empty
  assign show_badge = show_badge | default: true
  assign badge_text = badge_text | default: 'Best Seller'
  assign quickview_label = quickview_label | default: 'Quickview'

  unless product != empty
    break
  endunless

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign savings = product.compare_at_price | minus: product.price
    assign savings_percent = savings | times: 100.0 | divided_by: product.compare_at_price | round
  endif
%}

<article class="tabbed-card" aria-labelledby="tabbed-card-title-{{ product.id }}">
  <a href="{{ product.url }}" class="tabbed-card__link" tabindex="-1" aria-hidden="true"></a>

  <div class="tabbed-card__media">
    {% if product.featured_image %}
      {{
        product.featured_image
        | image_url: width: product.featured_image.width
        | image_tag:
          sizes: '(min-width: 990px) 20vw, 80vw',
          widths: '200,300,400,500,600',
          loading: 'lazy',
          class: 'tabbed-card__image',
          alt: product.featured_image.alt | default: product.title
      }}
    {% else %}
      <div class="tabbed-card__placeholder">
        {{ 'product-1' | placeholder_svg_tag: 'tabbed-card__placeholder-svg' }}
      </div>
    {% endif %}

    {% if show_badge and badge_text != blank %}
      <span class="tabbed-card__badge">{{ badge_text }}</span>
    {% endif %}
  </div>

  <div class="tabbed-card__content">
    <div class="tabbed-card__info">
      {% liquid
        assign rating_value = product.metafields.reviews.rating.value | default: nil
        assign review_count = product.metafields.reviews.rating_count | default: nil
      %}
      {% if rating_value != nil %}
        <div class="tabbed-card__rating" aria-label="{{ 'accessibility.rating' | t: rating: rating_value }}">
          <div class="tabbed-card__stars" aria-hidden="true">
            {% assign rating_floor = rating_value | floor %}
            {% assign rating_decimal = rating_value | minus: rating_floor %}
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                {% if i <= rating_floor %}
                  <path d="M8 0.5L10.163 5.0145L15.106 5.5885L11.412 9.0255L12.472 13.9115L8 11.394L3.528 13.9115L4.588 9.0255L0.894 5.5885L5.837 5.0145L8 0.5Z" fill="#FFB800"/>
                {% elsif i == rating_floor | plus: 1 and rating_decimal > 0 %}
                  <path d="M8 0.5L10.163 5.0145L15.106 5.5885L11.412 9.0255L12.472 13.9115L8 11.394L3.528 13.9115L4.588 9.0255L0.894 5.5885L5.837 5.0145L8 0.5Z" fill="#FFB800" fill-opacity="0.5"/>
                {% else %}
                  <path d="M8 0.5L10.163 5.0145L15.106 5.5885L11.412 9.0255L12.472 13.9115L8 11.394L3.528 13.9115L4.588 9.0255L0.894 5.5885L5.837 5.0145L8 0.5Z" fill="#E0E0E0"/>
                {% endif %}
              </svg>
            {% endfor %}
          </div>
          <div class="tabbed-card__rating-text">
            <span class="tabbed-card__rating-value">{{ rating_value }}</span>
            <span class="tabbed-card__rating-count">({{ review_count }})</span>
          </div>
        </div>
      {% endif %}

      <h3 id="tabbed-card-title-{{ product.id }}" class="tabbed-card__title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>

      <div class="tabbed-card__price">
        {% if on_sale %}
          <span class="sr-only">{{ 'content.price_sale' | t }},</span>
          <span class="tabbed-card__price-sale">{{ product.price | money }}</span>
          <span class="sr-only">{{ 'content.price_regular' | t }},</span>
          <s class="tabbed-card__price-compare">{{ product.compare_at_price | money }}</s>
          <span class="tabbed-card__discount-badge">{{ savings_percent }}% off</span>
        {% else %}
          <span class="tabbed-card__price-sale">{{ product.price | money }}</span>
        {% endif %}
      </div>
    </div>

    <a href="{{ product.url }}" class="tabbed-card__quickview">
      {{ quickview_label }}
    </a>
  </div>
</article>
